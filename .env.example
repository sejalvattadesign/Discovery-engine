# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# Primary LLM — Groq (OpenAI-compatible endpoint). Used for classification + RAG answers.
GROQ_API_KEY=

# Optional fallback provider (Claude). llm.py uses this if GROQ_API_KEY is absent.
ANTHROPIC_API_KEY=

# Only needed to RE-SCRAPE Reddit (cached data works without these).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
